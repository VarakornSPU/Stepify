@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";
}

<!-- Header -->
<div class="admin-header">
    <h1><i class="fa-solid fa-chart-line me-2 text-primary"></i>Dashboard</h1>
    <span class="badge bg-light text-dark px-3 py-2">
        <i class="fa-solid fa-calendar me-1"></i> @DateTime.Now.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("th-TH"))
    </span>
</div>

<!-- Stats Cards -->
<div class="row g-4 mb-4">
    <!-- Users Card -->
    <div class="col-md-6 col-xl-4">
        <div class="dashboard-card">
            <div class="dashboard-card-body">
                <div class="dashboard-card-icon users">
                    <i class="fa-solid fa-users"></i>
                </div>
                <p class="dashboard-card-title">ผู้ใช้งานทั้งหมด</p>
                <h2 class="dashboard-card-value">@ViewBag.TotalUsers</h2>
            </div>
            <div class="dashboard-card-footer">
                <a asp-action="ManageUsers" class="dashboard-card-link">
                    <span>จัดการผู้ใช้งาน</span>
                    <i class="fa-solid fa-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    <!-- Products Card -->
    <div class="col-md-6 col-xl-4">
        <div class="dashboard-card">
            <div class="dashboard-card-body">
                <div class="dashboard-card-icon products">
                    <i class="fa-solid fa-boxes-stacked"></i>
                </div>
                <p class="dashboard-card-title">สินค้าในระบบ</p>
                <h2 class="dashboard-card-value">@ViewBag.TotalProducts</h2>
            </div>
            <div class="dashboard-card-footer">
                <a asp-action="ManageProducts" class="dashboard-card-link">
                    <span>จัดการสินค้า</span>
                    <i class="fa-solid fa-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    <!-- Orders Card -->
    <div class="col-md-6 col-xl-4">
        <div class="dashboard-card">
            <div class="dashboard-card-body">
                <div class="dashboard-card-icon orders">
                    <i class="fa-solid fa-shopping-bag"></i>
                </div>
                <p class="dashboard-card-title">คำสั่งซื้อทั้งหมด</p>
                <h2 class="dashboard-card-value">@ViewBag.TotalOrders</h2>
            </div>
            <div class="dashboard-card-footer">
                <a href="#" class="dashboard-card-link">
                    <span>ดูคำสั่งซื้อ</span>
                    <i class="fa-solid fa-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-4">
    <div class="col-12">
        <div class="dashboard-card">
            <div class="dashboard-card-body">
                <h5 class="mb-4" style="font-family: var(--font-heading); font-weight: 600;">
                    <i class="fa-solid fa-bolt text-warning me-2"></i>Quick Actions
                </h5>
                <div class="d-flex flex-wrap gap-3">
                    <a asp-action="ManageUsers" class="btn btn-stepify-primary">
                        <i class="fa-solid fa-user-plus me-2"></i>เพิ่มผู้ใช้งาน
                    </a>
                    <a asp-action="ManageProducts" class="btn btn-stepify-success">
                        <i class="fa-solid fa-plus me-2"></i>เพิ่มสินค้าใหม่
                    </a>
                    <a href="/" class="btn btn-stepify-outline">
                        <i class="fa-solid fa-store me-2"></i>ดูหน้าร้านค้า
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
