@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "รายงานยอดขาย";
    var topProducts = ViewBag.TopProducts as IEnumerable<dynamic>;
}

<div class="container-fluid mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold"><i class="fa-solid fa-chart-pie text-primary"></i> รายงานยอดขายปี @ViewBag.CurrentYear</h3>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm bg-primary text-white h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="fs-1 me-4"><i class="fa-solid fa-sack-dollar"></i></div>
                    <div>
                        <h6 class="mb-1 opacity-75">ยอดขายรวมทั้งหมด (บาท)</h6>
                        <h2 class="mb-0 fw-bold">@ViewBag.TotalSales.ToString("N2") ฿</h2>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm bg-success text-white h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="fs-1 me-4"><i class="fa-solid fa-file-invoice"></i></div>
                    <div>
                        <h6 class="mb-1 opacity-75">จำนวนคำสั่งซื้อที่สำเร็จ (ออเดอร์)</h6>
                        <h2 class="mb-0 fw-bold">@ViewBag.TotalOrders รายการ</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-7 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold">กราฟยอดขายรายเดือน</h5>
                </div>
                <div class="card-body">
                    <canvas id="salesChart" height="250"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-5 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="fa-solid fa-trophy text-warning"></i> 5 อันดับสินค้าขายดี</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">ชื่อสินค้า</th>
                                <th class="text-center">จำนวนที่ขายได้</th>
                                <th class="text-end pe-4">สร้างรายได้</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (topProducts != null && topProducts.Any())
                            {
                                foreach (var item in topProducts)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold">@item.ProductName</td>
                                        <td class="text-center"><span class="badge bg-primary rounded-pill">@item.TotalSold คู่</span></td>
                                        <td class="text-end pe-4 text-success fw-bold">@item.TotalRevenue.ToString("N2") ฿</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="3" class="text-center py-4 text-muted">ยังไม่มีข้อมูลการขาย</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // ดึงข้อมูลยอดขาย 12 เดือนจาก C# มาใส่ใน JavaScript
        var chartDataArray = [@ViewBag.ChartData]; 

        var ctx = document.getElementById('salesChart').getContext('2d');
        var salesChart = new Chart(ctx, {
            type: 'bar', // เปลี่ยนเป็น 'line' ได้ถ้าอยากได้กราฟเส้น
            data: {
                labels: ['ม.ค.', 'ก.พ.', 'มี.ค.', 'เม.ย.', 'พ.ค.', 'มิ.ย.', 'ก.ค.', 'ส.ค.', 'ก.ย.', 'ต.ค.', 'พ.ย.', 'ธ.ค.'],
                datasets: [{
                    label: 'ยอดขาย (บาท)',
                    data: chartDataArray,
                    backgroundColor: 'rgba(41, 121, 255, 0.7)', // สีแท่งกราฟ
                    borderColor: 'rgba(41, 121, 255, 1)',
                    borderWidth: 1,
                    borderRadius: 5
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: { beginAtZero: true }
                }
            }
        });
    </script>
}