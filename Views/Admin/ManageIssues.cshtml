@model IEnumerable<Stepify.Models.Db.IssueReport>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "รายการแจ้งปัญหา";
}

<div class="admin-header">
    <h1><i class="fa-solid fa-triangle-exclamation me-2 text-danger"></i>รายการแจ้งปัญหา (Issue Reports)</h1>
</div>

<div class="admin-table-wrapper">
    <table class="table admin-table align-middle">
        <thead class="table-dark">
            <tr>
                <th style="width: 80px;" class="text-center">รหัส</th>
                <th>หัวข้อปัญหา</th>
                <th>รายละเอียด</th>
                <th>ผู้แจ้ง (Warehouse)</th>
                <th>วันที่แจ้ง</th>
                <th class="text-center">สถานะ</th>
                <th class="text-center pe-4">จัดการ</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center fw-semibold text-muted">#@item.IssueId</td>
                        <td class="fw-bold">@item.Title</td>
                        <td>@item.Description</td>
                        <td>
                            <span class="badge badge-role badge-warehouse"><i class="fa-solid fa-user me-1"></i>@item.ReportedBy</span>
                        </td>
                        <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-center">
                            @if (item.Status == "Pending")
                            {
                                <span class="badge bg-warning text-dark px-3 py-2"><i class="fa-regular fa-clock me-1"></i> รอดำเนินการ</span>
                            }
                            else if (item.Status == "Resolved")
                            {
                                <span class="badge bg-success px-3 py-2"><i class="fa-solid fa-check-circle me-1"></i> แก้ไขแล้ว</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary px-3 py-2">@item.Status</span>
                            }
                        </td>
                        <td class="text-center pe-4">
                            @if (item.Status == "Pending")
                            {
                                <form asp-controller="Admin" asp-action="UpdateIssueStatus" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@item.IssueId" />
                                    <input type="hidden" name="status" value="Resolved" /> 
                                    <button type="submit" class="btn btn-sm btn-outline-success" 
                                            onclick="return confirm('ยืนยันว่าแก้ไขปัญหานี้เรียบร้อยแล้ว?');">
                                        <i class="fa-solid fa-check"></i> เคลียร์ปัญหา
                                    </button>
                                </form>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-light text-muted" disabled>
                                    <i class="fa-solid fa-lock"></i> ปิดงานแล้ว
                                </button>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7">
                        <div class="empty-state py-5 text-center">
                            <i class="fa-solid fa-clipboard-check empty-state-icon text-success mb-3" style="font-size: 3rem;"></i>
                            <h3 class="empty-state-title">ไม่มีรายการแจ้งปัญหา</h3>
                            <p class="empty-state-text text-muted">การดำเนินงานในคลังสินค้าเป็นปกติ</p>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>