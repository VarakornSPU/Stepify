<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Stepify</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
    
    <!-- Stylesheets -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    
    <!-- Modular CSS Files -->
    <link rel="stylesheet" href="~/css/base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/navbar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/hero.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/products.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/footer.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-stepify sticky-top">
            <div class="container">
                <!-- Brand -->
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-shoe-prints"></i>
                    <span>Stepify</span>
                </a>
                
                <!-- Mobile Toggle -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarMain">
                    <!-- Main Navigation -->
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="fa-solid fa-house me-1"></i> หน้าแรก
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">
                                <i class="fa-solid fa-boxes-stacked me-1"></i> สินค้าทั้งหมด
                            </a>
                        </li>
                    </ul>

                    <!-- Search Form -->
                    <form class="search-form-wrapper d-flex me-3" asp-controller="Home" asp-action="Search" method="get">
                        <input class="form-control" type="search" name="keyword" placeholder="ค้นหารองเท้า..." aria-label="Search">
                        <button class="btn btn-search" type="submit">
                            <i class="fa-solid fa-magnifying-glass"></i>
                        </button>
                    </form>

                    <!-- Right Navigation -->
                    <ul class="navbar-nav align-items-center">
                        <!-- Cart -->
                        <li class="nav-item me-2">
                            <a class="cart-icon-wrapper" asp-controller="Cart" asp-action="Index" title="ตะกร้าสินค้า">
                                <i class="fa-solid fa-cart-shopping"></i>
                                <span class="cart-badge">0</span>
                            </a>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <!-- User Dropdown -->
                            <li class="nav-item dropdown user-dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fa-solid fa-circle-user me-1"></i>
                                    @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="Admin" asp-action="Index">
                                                <i class="fa-solid fa-gauge text-primary"></i> ไปหน้า Admin
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                    }
                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <i class="fa-solid fa-box-open text-secondary"></i> ประวัติการสั่งซื้อ
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Logout">
                                            <i class="fa-solid fa-right-from-bracket"></i> ออกจากระบบ
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <!-- Auth Buttons -->
                            <li class="nav-item me-2">
                                <a class="btn btn-auth-login" asp-controller="Auth" asp-action="Login">
                                    เข้าสู่ระบบ
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-auth-register" asp-controller="Auth" asp-action="Register">
                                    สมัครสมาชิก
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container py-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-stepify">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    <div class="footer-brand">
                        <i class="fa-solid fa-shoe-prints"></i>
                        <span>Stepify</span>
                    </div>
                    <p class="mb-0 small">Premium Sneaker Store - Step Into Your Style</p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <p class="mb-0 small">
                        &copy; 2026 Stepify. All rights reserved. |
                        <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
