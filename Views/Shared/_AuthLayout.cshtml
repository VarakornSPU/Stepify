<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Stepify Authentication</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* ปรับพื้นหลังให้เป็นสีเทาอ่อนสบายตา */
        body { 
            background-color: #f4f6f9; 
            height: 100vh;
            display: flex;
            flex-direction: column;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-light bg-white border-bottom shadow-sm mb-5">
            <div class="container justify-content-center py-2">
                <a class="navbar-brand fw-bold text-primary fs-3 m-0" href="/">
                    <i class="fa-solid fa-shoe-prints"></i> Stepify
                </a>
            </div>
        </nav>
    </header>

    <div class="container flex-grow-1">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="py-3 text-muted text-center mt-auto">
        <small>&copy; 2026 Stepify. All rights reserved.</small>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>