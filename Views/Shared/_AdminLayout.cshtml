<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Stepify Admin</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
    
    <!-- Stylesheets -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    
    <!-- Modular CSS Files (Admin specific) -->
    <link rel="stylesheet" href="~/css/base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar -->
        <aside class="admin-sidebar">
            <!-- Brand -->
            <a href="/Admin/Index" class="admin-brand text-decoration-none">
                <i class="fa-solid fa-shoe-prints"></i>
                <span>Stepify Admin</span>
            </a>
            
            <!-- Navigation -->
            <nav class="admin-nav">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a asp-controller="Admin" asp-action="Index" 
                           class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                            <i class="fa-solid fa-chart-line"></i>
                            <span>Dashboard</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Admin" asp-action="ManageUsers" 
                           class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "ManageUsers" || ViewContext.RouteData.Values["Action"]?.ToString() == "EditUser" ? "active" : "")">
                            <i class="fa-solid fa-users"></i>
                            <span>จัดการผู้ใช้งาน</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Admin" asp-action="ManageProducts" 
                           class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "ManageProducts" ? "active" : "")">
                            <i class="fa-solid fa-boxes-stacked"></i>
                            <span>จัดการสินค้า</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link disabled">
                            <i class="fa-solid fa-tags"></i>
                            <span>โปรโมชั่น</span>
                            <small class="ms-auto badge bg-secondary">Soon</small>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link disabled">
                            <i class="fa-solid fa-chart-pie"></i>
                            <span>รายงานยอดขาย</span>
                            <small class="ms-auto badge bg-secondary">Soon</small>
                        </a>
                    </li>
                </ul>
            </nav>
            
            <!-- User Profile -->
            <div class="admin-user">
                <div class="dropdown">
                    <button class="admin-user-btn dropdown-toggle" type="button" id="adminUserDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                        <img src="https://ui-avatars.com/api/?name=Admin&background=2979ff&color=fff&bold=true" 
                             alt="Admin" class="admin-user-avatar">
                        <div class="admin-user-info">
                            <div class="admin-user-name">Administrator</div>
                            <div class="admin-user-role">Super Admin</div>
                        </div>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="adminUserDropdown">
                        <li>
                            <a class="dropdown-item" href="/">
                                <i class="fa-solid fa-store me-2"></i> กลับไปหน้าร้านค้า
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item text-danger" href="/Auth/Logout">
                                <i class="fa-solid fa-right-from-bracket me-2"></i> ออกจากระบบ
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="admin-main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
