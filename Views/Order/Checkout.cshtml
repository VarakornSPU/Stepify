@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "ชำระเงิน (Checkout)";
    bool hasAddress = !string.IsNullOrWhiteSpace((string)ViewBag.UserAddress);
}

<div class="container my-5">
    <div class="row">
        <div class="col-md-7 mb-4">
            <h4 class="fw-bold mb-3"><i class="fa-solid fa-location-dot text-danger"></i> ข้อมูลการจัดส่ง</h4>
            
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <form id="checkoutForm" asp-action="PlaceOrder" method="post">
                        
                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <label class="form-label fw-bold mb-0">ที่อยู่จัดส่ง</label>
                                <button type="button" class="btn btn-sm btn-outline-primary fw-bold" onclick="enableEditAddress()">
                                    <i class="fa-solid fa-pen"></i> แก้ไขที่อยู่
                                </button>
                            </div>

                            <textarea id="addressField" name="ShippingAddress" 
                                      class="form-control @(hasAddress ? "bg-light" : "")" 
                                      rows="3" required 
                                      placeholder="กรุณากรอกที่อยู่จัดส่ง..." 
                                      @(hasAddress ? "readonly" : "")>@ViewBag.UserAddress</textarea>
                            
                            @* 🌟 ส่วนที่เพิ่ม: ปุ่มบันทึกที่อยู่ (จะโชว์เมื่อกดแก้ไข) *@
                            <div id="saveBtnContainer" class="mt-2 text-end" style="display: none;">
                                <button type="button" class="btn btn-success btn-sm fw-bold shadow-sm" onclick="saveAddressToProfile()">
                                    <i class="fa-solid fa-floppy-disk me-1"></i> บันทึกที่อยู่นี้ลงโปรไฟล์
                                </button>
                            </div>

                            <small class="text-muted d-block mt-1"><i class="fa-solid fa-circle-info"></i> ข้อมูลจะถูกใช้สำหรับคำสั่งซื้อนี้</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">ช่องทางการชำระเงิน</label>
                            <select name="PaymentMethod" class="form-select" required>
                                <option value="CreditCard">💳 บัตรเครดิต / เดบิต</option>
                                <option value="BankTransfer">🏦 โอนเงินผ่านธนาคาร</option>
                                <option value="COD">💵 เก็บเงินปลายทาง (COD)</option>
                            </select>
                        </div>

                        <input type="hidden" name="TotalAmount" value="@ViewBag.TotalAmount" />
                        <input type="hidden" name="DiscountAmount" id="FormDiscountAmount" value="@ViewBag.AutoDiscountAmount" />
                        <input type="hidden" name="NetAmount" id="FormNetAmount" value="@ViewBag.NetBeforeManualVoucher" />
                        <input type="hidden" name="UsedVoucherId" id="FormUsedVoucherId" value="" />
                        <input type="hidden" name="UsedPromotionId" id="FormUsedPromotionId" value="" />
                        
                        <button type="submit" class="btn btn-primary w-100 fw-bold mt-3 py-2 shadow">ยืนยันการสั่งซื้อ</button>
                    </form>
                </div>
            </div>

            <h4 class="fw-bold mb-3">สินค้าในตะกร้า</h4>
            <div class="card border-0 shadow-sm">
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @foreach(var item in Model) {
                            <li class="list-group-item d-flex justify-content-between align-items-center p-3">
                                <div>
                                    <h6 class="fw-bold mb-0">@item.Name</h6>
                                    <small class="text-muted">Size: @item.Size | Color: @item.Color</small>
                                </div>
                                <div class="text-end">
                                    <span class="badge bg-secondary rounded-pill me-2">x @item.Quantity</span>
                                    <span class="fw-bold">@item.SubTotal.ToString("N0") ฿</span>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        @* --- ส่วนสรุปยอดและคูปอง (เหมือนเดิม) --- *@
        <div class="col-md-5">
            <div class="card border-0 shadow-sm border-top border-primary border-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">สรุปคำสั่งซื้อ</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">ยอดรวมสินค้า:</span>
                        <span class="fw-bold">@ViewBag.TotalAmount.ToString("N0") ฿</span>
                    </div>
                    @if(ViewBag.AutoDiscountAmount > 0) {
                        <div class="d-flex justify-content-between mb-2 text-success">
                            <span>ส่วนลดอัตโนมัติ:</span>
                            <span class="fw-bold">-@ViewBag.AutoDiscountAmount.ToString("N0") ฿</span>
                        </div>
                    }
                    <div class="d-flex justify-content-between mb-3 text-danger" id="manualVoucherRow" style="display: none !important;">
                        <span>คูปองที่ใช้:</span>
                        <span class="fw-bold" id="ManualDiscountDisplay">0 ฿</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-bold fs-5">ยอดชำระสุทธิ:</span>
                        <span class="fw-bold fs-3 text-primary" id="NetDisplay">@ViewBag.NetBeforeManualVoucher.ToString("N0") ฿</span>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3"><i class="fa-solid fa-ticket text-danger me-2"></i> คูปองส่วนลด</h5>
                    @if (ViewBag.MyVouchers != null && ViewBag.MyVouchers.Count > 0) {
                        @foreach (var v in ViewBag.MyVouchers) {
                            <div class="border border-warning rounded-3 p-3 mb-2 d-flex justify-content-between align-items-center bg-light">
                                <div>
                                    <div class="fw-bold">@v.VoucherType</div>
                                    <small class="text-danger">ลด @v.DiscountValue.ToString("N0") @(v.IsPercent == true ? "%" : "฿")</small>
                                </div>
                                <button type="button" id="btnVoucher_@v.VoucherId" class="btn btn-warning btn-sm coupon-btn" onclick="toggleDiscount('@v.DiscountValue', '@v.IsPercent.ToString().ToLower()', '@v.VoucherId', 'Voucher')">ใช้</button>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // 🌟 1. เปิดโหมดแก้ไขที่อยู่
        function enableEditAddress() {
            let addrField = document.getElementById('addressField');
            addrField.readOnly = false;
            addrField.classList.remove('bg-light');
            addrField.focus();
            document.getElementById('saveBtnContainer').style.display = 'block';
        }

        // 🌟 2. ฟังก์ชัน AJAX บันทึกที่อยู่ลงโปรไฟล์ (เลียนแบบหน้า Profile)
        function saveAddressToProfile() {
            const address = document.getElementById('addressField').value;
            if (!address.trim()) {
                alert("กรุณากรอกที่อยู่ก่อนบันทึก");
                return;
            }

            // ส่งข้อมูลไปยัง AuthController/UpdateProfile (หรือสร้าง Action ใหม่)
            // ในที่นี้แนะนำให้สร้าง Action ง่ายๆ ใน OrderController
            fetch('/Order/UpdateProfileAddress', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ 'newAddress': address })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert("บันทึกที่อยู่ลงโปรไฟล์เรียบร้อยแล้ว");
                    document.getElementById('saveBtnContainer').style.display = 'none';
                    document.getElementById('addressField').classList.add('bg-light');
                    document.getElementById('addressField').readOnly = true;
                } else {
                    alert("เกิดข้อผิดพลาด: " + data.message);
                }
            })
            .catch(error => alert("ไม่สามารถบันทึกได้ในขณะนี้"));
        }

        // --- ส่วนระบบคูปองเดิม ---
        let autoDiscount = parseFloat('@ViewBag.AutoDiscountAmount');
        let originalTotal = parseFloat('@ViewBag.TotalAmount');
        let netBeforeVoucher = parseFloat('@ViewBag.NetBeforeManualVoucher');
        let activeCouponId = null;
        let activeCouponType = null;

        function toggleDiscount(discountValue, isPercent, itemId, type) {
            document.querySelectorAll('.coupon-btn').forEach(btn => {
                btn.innerText = 'ใช้';
                btn.classList.remove('btn-secondary');
                btn.classList.add(btn.id.startsWith('btnVoucher') ? 'btn-warning' : 'btn-outline-danger');
            });

            if (activeCouponId === itemId && activeCouponType === type) {
                activeCouponId = null; activeCouponType = null;
                document.getElementById('manualVoucherRow').style.setProperty("display", "none", "important");
                document.getElementById('NetDisplay').innerText = netBeforeVoucher.toLocaleString() + " ฿";
                document.getElementById('FormDiscountAmount').value = autoDiscount;
                document.getElementById('FormNetAmount').value = netBeforeVoucher;
                return;
            }

            activeCouponId = itemId; activeCouponType = type;
            let clickedBtn = document.getElementById('btn' + type + '_' + itemId);
            clickedBtn.innerText = 'ยกเลิก';
            clickedBtn.className = 'btn btn-secondary btn-sm coupon-btn';

            let manualDiscount = (isPercent === "true") ? netBeforeVoucher * (parseFloat(discountValue) / 100) : parseFloat(discountValue);
            let totalDiscount = autoDiscount + manualDiscount;
            let finalNet = Math.max(0, originalTotal - totalDiscount);

            document.getElementById('manualVoucherRow').style.setProperty("display", "flex", "important");
            document.getElementById('ManualDiscountDisplay').innerText = "-" + manualDiscount.toLocaleString() + " ฿";
            document.getElementById('NetDisplay').innerText = finalNet.toLocaleString() + " ฿";
            document.getElementById('FormDiscountAmount').value = totalDiscount;
            document.getElementById('FormNetAmount').value = finalNet;
            document.getElementById('FormUsedVoucherId').value = (type === 'Voucher' ? itemId : "");
            document.getElementById('FormUsedPromotionId').value = (type === 'Promo' ? itemId : "");
        }
    </script>
}