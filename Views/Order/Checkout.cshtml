@{
    Layout = "_Layout";
    ViewData["Title"] = "ชำระเงิน (Checkout)";
    var cartItems = ViewBag.CartItems as IEnumerable<dynamic>;
}

<div class="container mt-4 mb-5">
    <h3 class="fw-bold mb-4">ดำเนินการชำระเงิน (Checkout)</h3>

    <div class="row gx-5">
        <div class="col-md-7">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="fa-solid fa-location-dot text-primary"></i> ข้อมูลการจัดส่ง</h5>
                </div>
                <div class="card-body">
                    <form id="checkoutForm" asp-controller="Order" asp-action="PlaceOrder" method="post">
                        <input type="hidden" name="TotalAmount" value="@ViewBag.TotalAmount" />
                        <input type="hidden" name="DiscountAmount" value="@ViewBag.DiscountAmount" />
                        <input type="hidden" name="NetAmount" value="@ViewBag.NetAmount" />

                        <div class="mb-3">
                            <label class="form-label">ที่อยู่สำหรับจัดส่งอย่างละเอียด</label>
                            <textarea class="form-control" name="ShippingAddress" rows="4" required placeholder="บ้านเลขที่, ซอย, ถนน, ตำบล, อำเภอ, จังหวัด, รหัสไปรษณีย์"></textarea>
                        </div>

                        <h5 class="mb-3 mt-4 fw-bold"><i class="fa-solid fa-credit-card text-primary"></i> เลือกวิธีชำระเงิน</h5>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" name="PaymentMethod" id="pay1" value="CreditCard" required>
                            <label class="form-check-label" for="pay1">บัตรเครดิต / เดบิต</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" name="PaymentMethod" id="pay2" value="PromptPay">
                            <label class="form-check-label" for="pay2">สแกน QR Code (พร้อมเพย์)</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="PaymentMethod" id="pay3" value="COD">
                            <label class="form-check-label" for="pay3">เก็บเงินปลายทาง (COD)</label>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light py-3">
                    <h5 class="mb-0 fw-bold">สรุปคำสั่งซื้อ</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush mb-3">
                        @foreach (var item in cartItems)
                        {
                            <li class="list-group-item d-flex justify-content-between lh-sm px-0">
                                <div>
                                    <h6 class="my-0">@item.Name</h6>
                                    <small class="text-muted">ไซส์: @item.Size (@item.Color) x @item.Quantity</small>
                                </div>
                                <span class="text-muted">@item.SubTotal.ToString("N2")</span>
                            </li>
                        }
                    </ul>

                    <form asp-controller="Order" asp-action="Checkout" method="get" class="card p-2 mb-3 bg-light border-0">
                        <div class="input-group">
                            <input type="text" class="form-control" name="promoCode" value="@ViewBag.PromoCode" placeholder="กรอกโค้ดส่วนลด">
                            <button type="submit" class="btn btn-secondary">ใช้โค้ด</button>
                        </div>
                        @if (ViewBag.PromoMessage != null) { <small class="text-success mt-1">@ViewBag.PromoMessage</small> }
                        @if (ViewBag.PromoError != null) { <small class="text-danger mt-1">@ViewBag.PromoError</small> }
                    </form>

                    <div class="d-flex justify-content-between mb-2">
                        <span>ยอดรวมสินค้า</span>
                        <span>@ViewBag.TotalAmount.ToString("N2") ฿</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 text-success">
                        <span>ส่วนลด</span>
                        <span>- @ViewBag.DiscountAmount.ToString("N2") ฿</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-4">
                        <h5 class="fw-bold">ยอดชำระสุทธิ</h5>
                        <h4 class="fw-bold text-primary">@ViewBag.NetAmount.ToString("N2") ฿</h4>
                    </div>

                    <button type="submit" form="checkoutForm" class="btn btn-primary btn-lg w-100">ยืนยันสั่งซื้อสินค้า</button>
                </div>
            </div>
        </div>
    </div>
</div>