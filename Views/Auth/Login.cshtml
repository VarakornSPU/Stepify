@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Login";
}

<div class="auth-card">
    <div class="auth-header">
        <h4><i class="fa-solid fa-right-to-bracket me-2"></i>เข้าสู่ระบบ</h4>
    </div>
    <div class="auth-body">
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-stepify alert-danger mb-4">
                <i class="fa-solid fa-circle-exclamation me-2"></i>@ViewBag.Error
            </div>
        }

        <form asp-controller="Auth" asp-action="Login" method="post">
            <div class="mb-3">
                <label class="form-label">
                    <i class="fa-solid fa-envelope me-1 text-muted"></i> อีเมล
                </label>
                <input type="email" name="Email" class="form-control" placeholder="yourname@email.com" required>
            </div>
            <div class="mb-4">
                <label class="form-label">
                    <i class="fa-solid fa-lock me-1 text-muted"></i> รหัสผ่าน
                </label>
                <input type="password" name="Password" class="form-control" placeholder="กรอกรหัสผ่าน" required>
            </div>
            <div class="d-grid">
                <button type="submit" class="btn btn-auth btn-lg">
                    <i class="fa-solid fa-arrow-right-to-bracket me-2"></i>เข้าสู่ระบบ
                </button>
            </div>
        </form>

        <div class="auth-footer">
            <span class="text-muted">ยังไม่มีบัญชี?</span>
            <a asp-controller="Auth" asp-action="Register">สมัครสมาชิก</a>
        </div>
    </div>
</div>
