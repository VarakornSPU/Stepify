@model Stepify.Models.Db.User
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Register";
}

<div class="auth-card" style="max-width: 480px;">
    <div class="auth-header auth-header-register">
        <h4><i class="fa-solid fa-user-plus me-2"></i>สมัครสมาชิก</h4>
    </div>
    <div class="auth-body">
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-stepify alert-danger mb-4">
                <i class="fa-solid fa-circle-exclamation me-2"></i>@ViewBag.Error
            </div>
        }

        <form asp-controller="Auth" asp-action="Register" method="post">
            <div class="mb-3">
                <label class="form-label">
                    <i class="fa-solid fa-user me-1 text-muted"></i> ชื่อ-นามสกุล
                </label>
                <input type="text" asp-for="Username" class="form-control" placeholder="เช่น Somchai Jaidee" required>
            </div>
            <div class="mb-3">
                <label class="form-label">
                    <i class="fa-solid fa-envelope me-1 text-muted"></i> อีเมล
                </label>
                <input type="email" asp-for="Email" class="form-control" placeholder="yourname@email.com" required>
            </div>
            <div class="mb-3">
                <label class="form-label">
                    <i class="fa-solid fa-phone me-1 text-muted"></i> เบอร์โทรศัพท์
                </label>
                <input type="text" asp-for="Tel" class="form-control" placeholder="08X-XXX-XXXX">
            </div>
            <div class="mb-4">
                <label class="form-label">
                    <i class="fa-solid fa-lock me-1 text-muted"></i> รหัสผ่าน
                </label>
                <input type="password" asp-for="Password" class="form-control" placeholder="ตั้งรหัสผ่านอย่างน้อย 6 ตัวอักษร" required>
            </div>
            <div class="d-grid">
                <button type="submit" class="btn btn-auth btn-auth-register btn-lg">
                    <i class="fa-solid fa-check me-2"></i>สมัครสมาชิก
                </button>
            </div>
        </form>

        <div class="auth-footer">
            <span class="text-muted">มีบัญชีอยู่แล้ว?</span>
            <a asp-controller="Auth" asp-action="Login">เข้าสู่ระบบ</a>
        </div>
    </div>
</div>
