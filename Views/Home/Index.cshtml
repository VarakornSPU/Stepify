@{
    ViewData["Title"] = "Home Page";
    var products = ViewBag.Products as IEnumerable<dynamic>;
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="hero-content">
        <h1 class="hero-title">Step Into Your Style</h1>
        <p class="hero-subtitle">
            ค้นหารองเท้าที่ใช่ ในสไตล์ที่ชอบไปกับ Stepify<br>
            สมัครสมาชิกวันนี้ รับส่วนลดทันที 10%!
        </p>
        <a asp-controller="Auth" asp-action="Register" class="hero-btn">
            <i class="fa-solid fa-user-plus"></i>
            สมัครสมาชิกเลย
        </a>
    </div>
</section>

<!-- Products Section -->
<section class="py-4">
    @if (ViewBag.Keyword != null)
    {
        <h2 class="section-title">
            <i class="fa-solid fa-magnifying-glass"></i>
            ผลการค้นหา: "@ViewBag.Keyword"
        </h2>
    }
    else
    {
        <h2 class="section-title">
            <i class="fa-solid fa-fire"></i>
            สินค้ามาใหม่
        </h2>
    }

    @if (products != null && products.Any())
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
            @foreach (var item in products)
            {
                <div class="col">
                    <div class="card product-card">
                        <div class="card-img-wrapper">
                            <span class="brand-badge">@item.Brand</span>
                            <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name">
                        </div>
                        <div class="card-body">
                            <h5 class="product-name" title="@item.Name">@item.Name</h5>
                            <p class="product-price">@item.Price.ToString("N0") <small>THB</small></p>
                        </div>
                        <div class="card-footer">
                            <div class="d-flex gap-2">
                                <a href="/Product/Details/@item.ProductId" class="btn btn-detail flex-fill">
                                    <i class="fa-solid fa-eye me-1"></i> ดูเพิ่มเติม
                                </a>
                                <form asp-controller="Cart" asp-action="AddToCart" method="post" class="flex-fill">
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <button type="submit" class="btn btn-cart w-100">
                                        <i class="fa-solid fa-cart-plus"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="fa-solid fa-face-sad-tear empty-state-icon"></i>
            <h3 class="empty-state-title">ไม่พบสินค้าที่คุณค้นหา</h3>
            <p class="empty-state-text">ลองค้นหาด้วยคำค้นอื่น หรือดูสินค้าทั้งหมดของเรา</p>
            <a asp-action="Index" class="btn btn-stepify-primary">
                <i class="fa-solid fa-arrow-left me-1"></i> ดูสินค้าทั้งหมด
            </a>
        </div>
    }
</section>
