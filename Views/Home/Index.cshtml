@{
    ViewData["Title"] = "Home Page";
    var products = ViewBag.Products as IEnumerable<dynamic>;
}

<div class="p-5 mb-4 bg-light rounded-3 shadow-sm text-center" style="background: url('https://images.unsplash.com/photo-1556906781-9a412961c28c?auto=format&fit=crop&w=1600&q=80') no-repeat center center; background-size: cover;">
    <div class="container-fluid py-5" style="background-color: rgba(255, 255, 255, 0.85); border-radius: 15px;">
        <h1 class="display-5 fw-bold text-primary">Step Into Your Style</h1>
        <p class="col-md-8 mx-auto fs-5">ค้นหารองเท้าที่ใช่ ในสไตล์ที่ชอบไปกับ Stepify สมัครสมาชิกวันนี้รับส่วนลดทันที 10%!</p>
        <a asp-controller="Auth" asp-action="Register" class="btn btn-primary btn-lg">สมัครสมาชิกเลย</a>
    </div>
</div>

@if (ViewBag.Keyword != null)
{
    <h3 class="mb-4">🔍 ผลการค้นหาสำหรับ: <span class="text-primary">"@ViewBag.Keyword"</span></h3>
}
else
{
    <h3 class="mb-4 text-center">🔥 สินค้ามาใหม่ (New Arrivals)</h3>
}

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
    
    @if (products != null && products.Any())
    {
        foreach (var item in products)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 product-card">
                    <img src="@item.ImageUrl" class="card-img-top p-3" alt="@item.Name" style="height: 250px; object-fit: contain;">
                    
                    <div class="card-body d-flex flex-column">
                        <span class="badge bg-secondary mb-2 align-self-start">@item.Brand</span>
                        <h5 class="card-title text-truncate" title="@item.Name">@item.Name</h5>
                        <h4 class="text-success fw-bold mt-auto">@item.Price.ToString("N2") ฿</h4>
                    </div>
                    
                    <div class="card-footer bg-white border-top-0 pb-3">
                        <div class="d-grid gap-2">
                            <a href="/Product/Details/@item.ProductId" class="btn btn-outline-primary">รายละเอียด</a>
                            <a href="/Product/Details/@item.ProductId" class="btn btn-primary w-100">
    <i class="fa-solid fa-hand-pointer me-1"></i> เลือกไซส์ / สั่งซื้อ
</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <h4 class="text-muted">ไม่พบสินค้าที่คุณค้นหา 😢</h4>
            <a asp-action="Index" class="btn btn-outline-primary mt-3">ดูสินค้าทั้งหมด</a>
        </div>
    }

</div>

@section Scripts {
    <style>
        .product-card { transition: transform 0.2s ease-in-out; }
        .product-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; }
    </style>
}